# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/etrade

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d

# Razorpay (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (optional - for cloud image uploads; if not set, uses local /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional - for order confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ezoneshoppi <noreply@ezoneshoppi.com>

# Seed admin
ADMIN_EMAIL=admin@etrade.com
ADMIN_PASSWORD=Admin@12345
